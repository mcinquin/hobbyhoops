    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
