{
  "name": "hobbyhoops",
  "version": "1.22.2",
  "private": true,
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "predev": "node scripts/check-node.mjs",
    "dev": "next dev --webpack",
    "prebuild": "node scripts/check-node.mjs",
    "build": "next build --webpack",
    "typecheck": "tsc --noEmit",
    "prestart": "node scripts/check-node.mjs",
    "start": "next start",
    "lint": "eslint",
    "lint:md": "markdownlint-cli2",
    "audit:ci": "npm audit --audit-level=high",
    "ci": "node scripts/ci.mjs",
    "ci:full": "node scripts/ci.mjs --with-audit",
    "check": "npm run ci",
    "test": "vitest run",
    "clean": "node scripts/clean.mjs",
    "optimize:logo": "node scripts/optimize-logo.mjs",
    "generate:icons": "node scripts/generate-pwa-icons.mjs",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx}": "eslint --fix",
    "*.md": "markdownlint-cli2 --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.8.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "eslint": "^10.4.1",
    "eslint-config-next": "16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli2": "^0.22.1",
    "semantic-release": "^25.0.5",
    "tailwindcss": "^4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.8"
  }
}
